# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# AI & LLM APIs
ANTHROPIC_API_KEY=your_anthropic_key
RAINFOREST_API_KEY=your_rainforest_key

# Affiliate Networks
AMAZON_AFFILIATE_TAG=your_amazon_tag
FLIPKART_AFFILIATE_ID=your_flipkart_id
FLIPKART_AFFILIATE_TOKEN=your_flipkart_token
CUELINKS_API_KEY=your_cuelinks_key

# Translation
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Emails
RESEND_API_KEY=your_resend_key

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=your_posthog_host

# Firebase (for push notifications)
FIREBASE_SERVER_KEY=your_firebase_key

# Application
NEXT_PUBLIC_APP_URL=https://finezapp.com
NODE_ENV=development

# Database
DATABASE_URL=

# JWT Secret for API
JWT_SECRET=your_jwt_secret_change_me

# Feature Flags
NEXT_PUBLIC_ENABLE_VENDOR_MODE=true
NEXT_PUBLIC_ENABLE_AFFILIATE_PROGRAM=true
NEXT_PUBLIC_ENABLE_PRICE_ALERTS=true
